# Django core
DEBUG=true
SECRET_KEY=your-django-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL (local dev — use individual DB_* vars)
DB_NAME=happytummy
DB_USER=postgres
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=0

# PostgreSQL (Render — set automatically via render.yaml)
# DATABASE_URL=postgres://user:password@host:5432/dbname

# SMS (console | msg91 | twilio)
SMS_BACKEND=console
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_FLOW_ID=your_msg91_flow_id
MSG91_SENDER_ID=your_msg91_sender_id
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890

# Email (console backend used automatically when DEBUG=true)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
SMTP_HOST=your_smtp_host
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_USE_TLS=true
SMTP_TIMEOUT=10
SENDER_EMAIL=HappyTummy <no-reply@your-domain.com>

# Donation notifications
DONATION_CLAIM_BASE_URL=http://127.0.0.1:8000
DONATION_NOTIFICATIONS_ASYNC=true
DONATION_NOTIFICATION_WORKERS=2

# Media uploads (enabled automatically on Render; off locally unless needed)
SERVE_MEDIA=false
# MEDIA_ROOT=/var/data/media

# Production-only (set DEBUG=false)
# CSRF_TRUSTED_ORIGINS=https://your-happytummy-domain.com
# SECURE_SSL_REDIRECT=true
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=true
# SECURE_HSTS_PRELOAD=false
# SECURE_PROXY_SSL_HEADER=true
